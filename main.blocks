<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="V5#!hQY2_uiTf~/qw1|." x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="g*5r$(OM|GQo#HPNik=q"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace QBS {" line1="" line2="    export enum SoundEffect {" line3="        //% block=&quot;straight sound ➖&quot;" line4="        None = 0," line5="        //% block=&quot;expressive vibrato 〰️&quot;" line6="        Vibrato = 1" line7="    }" line8="" line9="    const cScaleFreqs = [" line10="        196, 220, 247, 262, 294, 330, 349, 392, 440," line11="        494, 523, 587, 659, 698, 784, 880, 988, 1047, 1175" line12="    ];" line13="" line14="    /**" line15="     * Plays a note that responds to how you move and touch the micro:bit." line16="     * Tilt Forward/Back for Sharps/Flats. " line17="     * The force of your touch controls Volume." line18="     * @param note the scale index (0-18), eg: 3" line19="     * @param effect choose whether to add vibrato" line20="     */" line21="    //% block=&quot;�� play expressive note $note || effect $effect&quot;" line22="    //% group=&quot;Music&quot;" line23="    //% note.min=0 note.max=18 note.defl=3" line24="    //% effect.defl=SoundEffect.None" line25="    //% expandableArgumentMode=&quot;toggle&quot;" line26="    //% weight=90" line27="    export function playExpressiveNote(note: number, effect?: SoundEffect): void {" line28="        let safeNote = Math.max(0, Math.min(18, Math.round(note)));" line29="        let baseFreq = cScaleFreqs[safeNote];" line30="" line31="        // --- 1. INTERNAL INTENSITY (The &quot;Tap Force&quot;) ---" line32="        // We calculate the intensity right here inside the block." line33="        let shock = Math.abs(input.acceleration(Dimension.Strength) - 1023);" line34="        // Map raw shock (0-1500) to intensity (0-100)" line35="        let intensity = Math.max(0, Math.min(100, Math.round(Math.map(shock, 0, 1500, 0, 100))));" line36="" line37="        // --- 2. VOLUME MAPPING ---" line38="        // 0 intensity -&gt; Vol 30 | 80+ intensity -&gt; Vol 255" line39="        let vol = Math.map(intensity, 0, 80, 30, 255);" line40="        vol = Math.max(30, Math.min(255, vol));" line41="        music.setVolume(vol);" line42="" line43="        // --- 3. PITCH SHIFT (Forward/Backward Tilt) ---" line44="        // Threshold: 20 degrees is ~340 milli-g" line45="        let tiltY = input.acceleration(Dimension.Y);" line46="        let finalFreq = baseFreq;" line47="" line48="        if (tiltY &lt; -340) {" line49="            finalFreq = baseFreq * 1.0595; // Sharp" line50="        } else if (tiltY &gt; 340) {" line51="            finalFreq = baseFreq * 0.9439; // Flat" line52="        }" line53="" line54="        // --- 4. SOUND OUTPUT &amp; DYNAMIC VIBRATO ---" line55="        if (effect === SoundEffect.Vibrato) {" line56="            let timeMs = input.runningTime();" line57="" line58="            // Vibrato speeds up as volume increases" line59="            // 200ms cycle (quiet) -&gt; 140ms cycle (loud)" line60="            let cycleTimeMs = Math.map(vol, 30, 255, 200, 140);" line61="" line62="            let angle = ((timeMs % cycleTimeMs) / cycleTimeMs) * 2 * Math.PI;" line63="            let maxPitchShift = finalFreq * 0.015;" line64="            let smoothShift = Math.sin(angle) * maxPitchShift;" line65="" line66="            music.ringTone(Math.round(finalFreq + smoothShift));" line67="        } else {" line68="            music.ringTone(finalFreq);" line69="        }" line70="    }" line71="" line72="    /**" line73="     * Stops any continuous music playing." line74="     */" line75="    //% block=&quot;�� stop music&quot;" line76="    //% group=&quot;Music&quot;" line77="    //% weight=70" line78="    export function stopMusic(): void {" line79="        music.ringTone(0);" line80="    }" line81="}" numlines="82"></mutation></block></statement></block></xml>